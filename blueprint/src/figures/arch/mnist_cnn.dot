// MNIST 2D CNN (S4TF Chapter 2 match — no BN, 2 conv layers)
// Generated for blueprint Chapter "CNN: Convolution and Pooling" — 3,489,130 params
// Architecture mirrors mnistCnnNoBn in MainAblation.lean. BN is Chapter 5.
// Render: dot -Tpdf mnist_cnn.dot -o mnist_cnn.pdf
//         dot -Tsvg mnist_cnn.dot -o mnist_cnn.svg
digraph mnist_cnn {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=11, nodesep=0.3, ranksep=0.5,
         label="MNIST 2D CNN (S4TF-style, no BN) — 3,489,130 params",
         labelloc=b, fontsize=13];
  node [fontname="Helvetica", fontsize=9, style="rounded,filled"];
  edge [color="#888888", arrowsize=0.6, penwidth=0.8];

  // Input: 28×28×1 grayscale
  input [shape=ellipse, fillcolor="#e8f0ff", color="#4060a0",
         label="Input\n28×28×1"];

  // Two 3×3 convs at 32 channels, ReLU, no BN
  c1 [shape=box, fillcolor="#fff0e8", color="#c07040",
      label="Conv2D\n1 → 32 ch\n3×3, ReLU\n320 p"];
  c2 [shape=box, fillcolor="#fff0e8", color="#c07040",
      label="Conv2D\n32 → 32 ch\n3×3, ReLU\n9,248 p"];

  // Max-pool halves spatial resolution
  p1 [shape=box, fillcolor="#e8f0ff", color="#4060a0",
      label="maxPool\n2×2\n28→14"];

  // Flatten, then three dense layers with the fat 6272→512 first layer
  fl [shape=box, fillcolor="#f0e8ff", color="#6040a0",
      label="flatten\n14×14×32\n→ 6272"];
  d1 [shape=box, fillcolor="#ffe8e8", color="#c04040",
      label="Dense\n6272 → 512\nReLU\n3,211,776 p"];
  d2 [shape=box, fillcolor="#ffe8e8", color="#c04040",
      label="Dense\n512 → 512\nReLU\n262,656 p"];
  d3 [shape=box, fillcolor="#ffe8e8", color="#c04040",
      label="Dense\n512 → 10\n(identity)\n5,130 p"];

  // Output: class logits
  out [shape=ellipse, fillcolor="#e8ffe8", color="#40a060",
       label="Logits\n10 classes"];

  input -> c1 -> c2 -> p1 -> fl -> d1 -> d2 -> d3 -> out;
}
