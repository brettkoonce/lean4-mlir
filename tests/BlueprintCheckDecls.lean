import Lake.CLI.Main

/-! # `lake exe blueprint-checkdecls` — split-aware blueprint declaration check

A repo-owned variant of `PatrickMassot/checkdecls` (same logic, one filter):
verify that every declaration the blueprint references (`blueprint/lean_decls`,
generated by `leanblueprint web`) exists — importing the roots of every lib
EXCEPT `CertsHeavy`. The upstream tool imports every lib of the workspace, and
after the 2026-07-12 `Certs`→`CertsHeavy` split that means importing heavy
oleans the blueprint workflow deliberately does not build (they OOM'd the
shared runners; that's why the split exists). The blueprint text only cites
core declarations, so the filtered import set is the honest one — if a
blueprint chapter ever cites a heavy-corpus theorem, add that module here
explicitly rather than re-importing the whole heavy lib. -/

open Lake Lean

unsafe def main (args : List String) : IO UInt32 := do
  unless args.length == 1 do
    println! "This command takes exactly one argument: the path to a file \
      containing a list of declarations to check."
    return 1
  let filename : System.FilePath := args[0]!
  unless ← filename.pathExists do
    println! "Could not find declaration list {filename}."
    return 1
  let (elanInstall?, leanInstall?, lakeInstall?) ← findInstall?
  let config ← MonadError.runEIO <| mkLoadConfig { elanInstall?, leanInstall?, lakeInstall? }
  let (ws?, log) ← (loadWorkspace config).run?
  log.replay (logger := .stderr)
  let some ws := ws? | return 1
  let coreLibs := ws.root.leanLibs.filter fun lib => lib.name != `CertsHeavy
  let imports := coreLibs.flatMap (·.config.roots.map fun module => { module })
  -- see comments in https://github.com/leanprover/lean4/pull/6325
  enableInitializersExecution
  let env ← Lean.importModules imports {}
  let mut ok := true
  for line in ← IO.FS.lines filename do
    unless env.contains line.toName do
      println! "{line} is missing."
      ok := false
  return if ok then 0 else 1
