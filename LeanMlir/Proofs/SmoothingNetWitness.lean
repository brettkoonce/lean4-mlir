/-- **CERTIFY for the CONCRETE net.** `smoothing_cp_certified_net` with the
    classifier = `mlpT`'s argmax: measurability and `hp` interiority both
    DISCHARGED (continuity + the ten witnesses above). With probability
    `≥ 1 − α` over the `N` Gaussian samples: if the vote count for `y` at
    `x` comes out `k₀`, every `‖δ‖ < σ·Φ⁻¹(q₀)` leaves `y` the strict
    argmax of the smoothed `mlpT`. -/
theorem smoothing_cp_certified_mlpT {σ : ℝ} (hσ : 0 < σ)
    (x : EuclideanSpace ℝ (Fin 49)) (y : Fin 10)
    {N k₀ : ℕ} (hk₀ : k₀ ≤ N) {α q₀ : ℝ} (hα : 0 ≤ α) (hα1 : α < 1)
    (hq₀ : q₀ ∈ Set.Ioo (0:ℝ) 1) (htail : binomTail N k₀ q₀ ≤ α) :
    1 - α
      ≤ (Measure.pi fun _ : Fin N => stdGaussian (EuclideanSpace ℝ (Fin 49))).real
          {ω | (∑ i, if argmaxNet (fun v j => mlpT v j) (x + σ • ω i) = y then 1 else 0) = k₀ →
            ∀ δ : EuclideanSpace ℝ (Fin 49),
            ‖δ‖ < σ * stdNormalQuantile q₀ →
            ∀ j, j ≠ y →
              (∫ z, (if argmaxNet (fun v j => mlpT v j) (x + δ + σ • z) = j then (1:ℝ) else 0)
                  ∂(stdGaussian (EuclideanSpace ℝ (Fin 49))))
                < ∫ z, (if argmaxNet (fun v j => mlpT v j) (x + δ + σ • z) = y then (1:ℝ) else 0)
                    ∂(stdGaussian (EuclideanSpace ℝ (Fin 49)))} :=
  smoothing_cp_certified_net hσ mlpT_logit_continuous netW netW_strict
    x y hk₀ hα hα1 hq₀ htail

/-- The deployed-protocol demo: at the scorecard's `N = 10112`, `α = 1/1000`,
    a count of `10084` certifies radius `σ·Φ⁻¹(0.9952)` for the smoothed
    `mlpT` — the per-image scorecard shape with NO abstract-classifier
    hypotheses left (the tail check is one kernel evaluation). -/
theorem smooth_cp_mlpT_demo {σ : ℝ} (hσ : 0 < σ)
    (x : EuclideanSpace ℝ (Fin 49)) (y : Fin 10) :
    1 - 1/(1000:ℝ)
      ≤ (Measure.pi fun _ : Fin 10112 => stdGaussian (EuclideanSpace ℝ (Fin 49))).real
          {ω | (∑ i, if argmaxNet (fun v j => mlpT v j) (x + σ • ω i) = y then 1 else 0) = 10084 →
            ∀ δ : EuclideanSpace ℝ (Fin 49),
            ‖δ‖ < σ * stdNormalQuantile ((9952:ℝ)/10000) →
            ∀ j, j ≠ y →
              (∫ z, (if argmaxNet (fun v j => mlpT v j) (x + δ + σ • z) = j then (1:ℝ) else 0)
                  ∂(stdGaussian (EuclideanSpace ℝ (Fin 49))))
                < ∫ z, (if argmaxNet (fun v j => mlpT v j) (x + δ + σ • z) = y then (1:ℝ) else 0)
                    ∂(stdGaussian (EuclideanSpace ℝ (Fin 49)))} :=
  smoothing_cp_certified_mlpT hσ x y (by norm_num) (by norm_num) (by norm_num)
    (by constructor <;> norm_num)
    (binomTail_le_of_kernel_check (by norm_num) (by norm_num) (by norm_num)
      (by norm_num) (by decide +kernel))

