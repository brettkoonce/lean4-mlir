set_option maxRecDepth 16384 in
set_option maxHeartbeats 16000000 in
theorem S3 : ∀ k : Fin (2*3*3),
    pdiv ((dense W5 b5 ∘ (relu 8 ∘ dense W4 b4)) ∘ (relu 8 ∘ dense W3 b3)) p2f k ⟨7, by norm_num⟩ = t3V k := by
  intro k
