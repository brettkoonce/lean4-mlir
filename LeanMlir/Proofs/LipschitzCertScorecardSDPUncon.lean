        = ∑ t, (W2t 1 t - W2t 4 t) * max (denseE W1t w t) 0 :=
      mlp_gap_eq W1t W2t 1 4 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP14U_eq t]
  rw [e u, e u']
