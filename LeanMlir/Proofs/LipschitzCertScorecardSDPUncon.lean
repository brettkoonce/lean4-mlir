theorem sP19U_def : ∀ a b, sP19U a b
    = 2 * (if a = b then tP19U a else 0) - vP19U a * vP19U b
      - (1/((95710089 : ℝ)/50000)) * (tP19U a * (G1t a b * tP19U b)) := by
