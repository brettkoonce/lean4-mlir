theorem vP34U_eq : ∀ t, vP34U t = W2t 3 t - W2t 4 t := by
  intro t
  fin_cases t <;>
    · simp [vP34U, W2t]
      try norm_num

theorem tP34U_nonneg : ∀ k, 0 ≤ tP34U k := by
