theorem sP34U_def : ∀ a b, sP34U a b
    = 2 * (if a = b then tP34U a else 0) - vP34U a * vP34U b
      - (1/((236579159 : ℝ)/125000)) * (tP34U a * (G1t a b * tP34U b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [sP34U, tP34U, vP34U, G1t]
      try norm_num

