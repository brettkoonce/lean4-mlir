theorem sP89U_def : ∀ a b, sP89U a b
    = 2 * (if a = b then tP89U a else 0) - vP89U a * vP89U b
      - (1/((175711823 : ℝ)/250000)) * (tP89U a * (G1t a b * tP89U b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [sP89U, tP89U, vP89U, G1t]
      try norm_num

set_option maxHeartbeats 3200000 in
theorem sP89U_ldl : ∀ a b, sP89U a b = ∑ i, lP89U a i * (dP89U i * lP89U b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [sP89U, lP89U, dP89U, Fin.sum_univ_succ]
      try norm_num

theorem pairSqU_8_9 : ∀ u u' : EuclideanSpace ℝ (Fin 49),
    ((mlpT u 8 - mlpT u 9) - (mlpT u' 8 - mlpT u' 9)) ^ 2
      ≤ ((175711823 : ℝ)/250000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 49), mlpT w 8 - mlpT w 9
      = ∑ t, vP89U t * max (denseE W1t w t) 0 := by
    intro w
    have h : mlpT w 8 - mlpT w 9
        = ∑ t, (W2t 8 t - W2t 9 t) * max (denseE W1t w t) 0 :=
      mlp_gap_eq W1t W2t 8 9 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP89U_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1t G1t G1t_eq vP89U tP89U tP89U_nonneg (by norm_num)
    (lipsdp_slack_of_cert G1t sP89U lP89U vP89U tP89U dP89U dP89U_nonneg
      sP89U_def sP89U_ldl) u u'

