theorem vP89C_eq : ∀ t, vP89C t = W2s 8 t - W2s 9 t := by
  intro t
  fin_cases t <;>
    · simp [vP89C, W2s]
      try norm_num

theorem tP89C_nonneg : ∀ k, 0 ≤ tP89C k := by
  intro k
  fin_cases k <;>
    · simp [tP89C]
      try norm_num

theorem dP89C_nonneg : ∀ i, 0 ≤ dP89C i := by
  intro i
  fin_cases i <;>
    · simp [dP89C]
      try norm_num

set_option maxHeartbeats 3200000 in
theorem sP89C_def : ∀ a b, sP89C a b
    = 2 * (if a = b then tP89C a else 0) - vP89C a * vP89C b
      - (1/((1224737 : ℝ)/12500)) * (tP89C a * (G1s a b * tP89C b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [sP89C, tP89C, vP89C, G1s]
      try norm_num

set_option maxHeartbeats 3200000 in
theorem sP89C_ldl : ∀ a b, sP89C a b = ∑ i, lP89C a i * (dP89C i * lP89C b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [sP89C, lP89C, dP89C, Fin.sum_univ_succ]
      try norm_num

theorem pairSqC_8_9 : ∀ u u' : EuclideanSpace ℝ (Fin 49),
    ((mlpS u 8 - mlpS u 9) - (mlpS u' 8 - mlpS u' 9)) ^ 2
      ≤ ((1224737 : ℝ)/12500) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 49), mlpS w 8 - mlpS w 9
      = ∑ t, vP89C t * max (denseE W1s w t) 0 := by
    intro w
    have h : mlpS w 8 - mlpS w 9
        = ∑ t, (W2s 8 t - W2s 9 t) * max (denseE W1s w t) 0 :=
      mlp_gap_eq W1s W2s 8 9 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP89C_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1s G1s G1s_eq vP89C tP89C tP89C_nonneg (by norm_num)
    (lipsdp_slack_of_cert G1s sP89C lP89C vP89C tP89C dP89C dP89C_nonneg
      sP89C_def sP89C_ldl) u u'

