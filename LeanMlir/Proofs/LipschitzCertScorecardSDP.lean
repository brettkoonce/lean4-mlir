theorem vP38C_eq : ∀ t, vP38C t = W2s 3 t - W2s 8 t := by
  intro t
  fin_cases t <;>
    · simp [vP38C, W2s]
      try norm_num

theorem tP38C_nonneg : ∀ k, 0 ≤ tP38C k := by
  intro k
  fin_cases k <;>
    · simp [tP38C]
      try norm_num

theorem dP38C_nonneg : ∀ i, 0 ≤ dP38C i := by
  intro i
  fin_cases i <;>
    · simp [dP38C]
      try norm_num

set_option maxHeartbeats 3200000 in
theorem sP38C_def : ∀ a b, sP38C a b
    = 2 * (if a = b then tP38C a else 0) - vP38C a * vP38C b
      - (1/((110010597 : ℝ)/1000000)) * (tP38C a * (G1s a b * tP38C b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [sP38C, tP38C, vP38C, G1s]
      try norm_num

set_option maxHeartbeats 3200000 in
theorem sP38C_ldl : ∀ a b, sP38C a b = ∑ i, lP38C a i * (dP38C i * lP38C b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [sP38C, lP38C, dP38C, Fin.sum_univ_succ]
      try norm_num

theorem pairSqC_3_8 : ∀ u u' : EuclideanSpace ℝ (Fin 49),
    ((mlpS u 3 - mlpS u 8) - (mlpS u' 3 - mlpS u' 8)) ^ 2
      ≤ ((110010597 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 49), mlpS w 3 - mlpS w 8
      = ∑ t, vP38C t * max (denseE W1s w t) 0 := by
    intro w
    have h : mlpS w 3 - mlpS w 8
        = ∑ t, (W2s 3 t - W2s 8 t) * max (denseE W1s w t) 0 :=
      mlp_gap_eq W1s W2s 3 8 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP38C_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1s G1s G1s_eq vP38C tP38C tP38C_nonneg (by norm_num)
    (lipsdp_slack_of_cert G1s sP38C lP38C vP38C tP38C dP38C dP38C_nonneg
      sP38C_def sP38C_ldl) u u'

