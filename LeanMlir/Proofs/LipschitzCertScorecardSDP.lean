theorem sP01C_def : ∀ a b, sP01C a b
    = 2 * (if a = b then tP01C a else 0) - vP01C a * vP01C b
      - (1/((81713231 : ℝ)/250000)) * (tP01C a * (G1s a b * tP01C b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [sP01C, tP01C, vP01C, G1s]
      try norm_num

