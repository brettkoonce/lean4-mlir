    ((12243679 : ℝ)/2785280) ≤ mlpSF imgF50 6 - mlpSF imgF50 j := by
  have hout : ∀ jj : Fin 10, mlpSF imgF50 jj =
      ∑ k : Fin 16, W2SF jj k * max (hpreSF50 k) 0 := by
    intro jj
    show denseE W2SF (reluE (denseE W1SF imgF50)) jj = _
    rw [denseE_apply]
    refine Finset.sum_congr rfl fun k _ => ?_
    rw [reluE_apply, hpreSF50_eval k]
  intro j hj
  fin_cases j <;>
    first
    | exact absurd rfl hj
    | · rw [hout, hout]
        simp [W2SF, hpreSF50, Fin.sum_univ_succ, max_def]
        norm_num

