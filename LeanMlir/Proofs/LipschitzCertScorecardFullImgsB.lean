    rw [denseE_apply]
    refine Finset.sum_congr rfl fun k _ => ?_
    rw [reluE_apply, hpreTF99_eval k]
  intro j hj
  fin_cases j <;>
    first
    | exact absurd rfl hj
    | · rw [hout, hout]
        simp [W2TF, hpreTF99, Fin.sum_univ_succ, max_def]
        norm_num

end LipschitzCertDemo
end Proofs
