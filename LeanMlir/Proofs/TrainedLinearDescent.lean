      1 - softmax 10 (dense Wd bd xd) lblD := by
    rw [show oneHot 10 lblD lblD = 1 from if_pos rfl,
        abs_of_nonpos (by linarith [sm_le_one lblD]), neg_sub]
  have hs := sm_pos lblD
  linarith [hsplit, hsplit1, herase, hlbl]

/-- `ќ£в±Љ (softmaxв±Љ вИТ onehotв±Љ)¬≤ вЙ• 1/4` вАФ the label term alone, via
    `softmax_lbl вЙ§ 1/2`. -/
theorem sm_cot_sq :
    (1 : вДЭ) / 4 вЙ§ вИС j, (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) ^ 2 := by
  have hterm : (1 : вДЭ) / 4 вЙ§
      (softmax 10 (dense Wd bd xd) lblD - oneHot 10 lblD lblD) ^ 2 := by
    rw [show oneHot 10 lblD lblD = 1 from if_pos rfl]
    nlinarith [sm_lbl_le_half, (sm_pos lblD).le]
  exact hterm.trans (Finset.single_le_sum
    (f := fun j => (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) ^ 2)
    (fun j _ => sq_nonneg _) (Finset.mem_univ lblD))

-- вФАвФА the gradient sums, bracketed by exact rationals вФАвФА

theorem grad_key (i : Fin 49) (j : Fin 10) :
    gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) (finProdFinEquiv (i, j)) =
      xd i * (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) := by
  rw [linear_loss_gradAt, Mat.unflatten_flatten]

/-- `ќ£|вИЗL| вЙ§ ((15367 : вДЭ)/1020)` (= 2¬Јќ£xбµҐ, exact). -/
theorem gradL1_le :
    (вИС idx, |gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx|) вЙ§ ((15367 : вДЭ)/1020) := by
  rw [вЖР finProdFinEquiv.sum_comp (fun idx => |gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx|)]
  rw [Fintype.sum_prod_type]
  simp_rw [grad_key]
  calc (вИС i : Fin 49, вИС j : Fin 10,
        |xd i * (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j)|)
      = вИС i : Fin 49, xd i * вИС j : Fin 10,
          |softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j| := by
        refine Finset.sum_congr rfl fun i _ => ?_
        rw [Finset.mul_sum]
        refine Finset.sum_congr rfl fun j _ => ?_
        rw [abs_mul, abs_of_nonneg (xd_nonneg i)]
    _ вЙ§ вИС i : Fin 49, xd i * 2 :=
        Finset.sum_le_sum fun i _ =>
          mul_le_mul_of_nonneg_left sm_cot_l1 (xd_nonneg i)
    _ = 2 * вИС i, xd i := by
        rw [вЖР Finset.sum_mul, mul_comm]
    _ = ((15367 : вДЭ)/1020) := by rw [xd_sum]; norm_num

/-- `ќ£(вИЗL)¬≤ вЙ• ((1511461 : вДЭ)/332928)/4` (= (ќ£xбµҐ¬≤)/4, exact). -/
theorem gradSq_lower :
    ((1511461 : вДЭ)/332928) / 4 вЙ§ вИС idx, gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx ^ 2 := by
  rw [вЖР finProdFinEquiv.sum_comp (fun idx => gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx ^ 2)]
  rw [Fintype.sum_prod_type]
  simp_rw [grad_key]
  have hfac : (вИС i : Fin 49, вИС j : Fin 10,
      (xd i * (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j)) ^ 2) =
      (вИС i, xd i ^ 2) * вИС j : Fin 10,
        (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) ^ 2 := by
    rw [Finset.sum_mul]
    refine Finset.sum_congr rfl fun i _ => ?_
    rw [Finset.mul_sum]
    refine Finset.sum_congr rfl fun j _ => ?_
    ring
  rw [hfac]
  have hB0 : (0:вДЭ) вЙ§ вИС i, xd i ^ 2 := Finset.sum_nonneg fun i _ => sq_nonneg _
  calc ((1511461 : вДЭ)/332928) / 4 = ((1511461 : вДЭ)/332928) * (1/4) := by norm_num
    _ = (вИС i, xd i ^ 2) * (1/4) := by rw [xd_sq_sum]
    _ вЙ§ (вИС i, xd i ^ 2) * вИС j : Fin 10,
        (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) ^ 2 :=
        mul_le_mul_of_nonneg_left sm_cot_sq hB0

-- вФАвФА the float-side budgets, evaluated вФАвФА

/-- Float-forward drift: `denseErr` at `b = 0`, `e = 0`, evaluated exactly per
    class column вАФ `((1+2вБї¬≤вБі)вБµ¬є вИТ 1)¬Јќ£бµҐ|WбµҐвВЦ|¬Ј|xбµҐ| вЙ§ ((1 : вДЭ)/25000)`. -/
theorem hdelta : вИА k, |binary32.dense Wd bd xd k - dense Wd bd xd k| вЙ§
    ((1 : вДЭ)/25000) := by
  intro k
  refine (binary32.dense_close_fresh Wd bd xd k).trans ?_
  simp only [FloatModel.denseErr, binary32_u]
  fin_cases k <;>
    ¬Ј simp [Wd, xd, bd, Fin.sum_univ_succ]
      norm_num [u32]

theorem hrho : FloatModel.smRho binary32.u 0 10 < 1 := by
  simp only [FloatModel.smRho, binary32_u]
  norm_num [u32]

/-- The gradient-oracle budget `ќЈ = mulErr u32 1 1 0 (cotErr u32 0 ќі 10)`,
    bounded by `((81 : вДЭ)/1000000)` вАФ the `exp(2ќі)вИТ1` term via the ќ≥-form. -/
theorem heta : FloatModel.mulErr binary32.u 1 1 0
    (FloatModel.cotErr binary32.u 0 ((1 : вДЭ)/25000) 10) вЙ§ ((81 : вДЭ)/1000000) := by
  have hE : Real.exp (2 * ((1 : вДЭ)/25000)) - 1 вЙ§ ((801 : вДЭ)/10000000) :=
    (FloatModel.exp_sub_one_le (by norm_num)).trans (by norm_num)
  simp only [FloatModel.mulErr, FloatModel.cotErr, FloatModel.smErr,
    FloatModel.smKappa, FloatModel.smRho, binary32_u]
  norm_num [u32]
  nlinarith [hE]

theorem heta0 : 0 вЙ§ FloatModel.mulErr binary32.u 1 1 0
    (FloatModel.cotErr binary32.u 0 ((1 : вДЭ)/25000) 10) := by
  have hE0 : (0:вДЭ) вЙ§ Real.exp (2 * ((1 : вДЭ)/25000)) - 1 := by
    nlinarith [Real.add_one_le_exp (2 * ((1 : вДЭ)/25000))]
  simp only [FloatModel.mulErr, FloatModel.cotErr, FloatModel.smErr,
    FloatModel.smKappa, FloatModel.smRho, binary32_u]
  norm_num [u32]
  nlinarith [hE0]

-- вФАвФА the capstone вФАвФА

set_option maxRecDepth 8192 in
/-- **Descent at TRAINED weights.** One binary32 SGD step (lr = ((1 : вДЭ)/8192)) on
    the trained linear classifier, at the misclassified witness, decreases
    the real cross-entropy by вЙ• lr¬ЈвАЦвИЗLвАЦ¬≤/2 вАФ every hypothesis of
    `linear_float_sgd_descends` discharged, the rounding model constructed
    (`rndP 23`), zero axioms. Retires the `W = 0` degeneracy caveat of
    `binary32_linear_sgd_descends_concrete`. -/
theorem trained_linear_sgd_descends_concrete :
    crossEntropy 10 (dense (Mat.unflatten (Mat.flatten Wd -
        ((1 : вДЭ)/8192) вАҐ binary32.linearFloatGrad Wd bd xd Real.exp lblD)) bd xd)
        lblD вЙ§
      crossEntropy 10 (dense (Mat.unflatten (Mat.flatten Wd)) bd xd) lblD -
        ((1 : вДЭ)/8192) * (вИС idx, gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx ^ 2) / 2 := by
  have hS1 := gradL1_le
  have hS2 := gradSq_lower
  have hS10 : (0:вДЭ) вЙ§ вИС idx, |gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx| :=
    Finset.sum_nonneg fun _ _ => abs_nonneg _
  have hќЈ := heta
  have hќЈ0 := heta0
  have hfexp : вИА t, |Real.exp t - Real.exp t| вЙ§ (0:вДЭ) * Real.exp t := by
    intro t; simp
  refine linear_float_sgd_descends binary32 Wd bd xd lblD Real.exp
    (lr := ((1 : вДЭ)/8192)) (a := 1) (eexp := 0) (ќі := ((1 : вДЭ)/25000))
    (by norm_num) xd_le_one (by norm_num) le_rfl (by norm_num) (by norm_num)
    hfexp hrho hdelta ?_ ?_ ?_
  ¬Ј -- hsmall
    push_cast
    nlinarith [hS1, hS10, hќЈ, hќЈ0]
  ¬Ј -- h1
    push_cast
    nlinarith [hS1, hS2, hS10, hќЈ, hќЈ0]
  ¬Ј -- h2
    set S1 := вИС idx, |gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx| with hS1def
    set S2 := вИС idx, gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx ^ 2 with hS2def
    set ќЈ := FloatModel.mulErr binary32.u 1 1 0
      (FloatModel.cotErr binary32.u 0 ((1 : вДЭ)/25000) 10) with hќЈdef
    have hD : ((1 : вДЭ)/8192) * (S1 + ((49 * 10 : вДХ) : вДЭ) * ќЈ) вЙ§ ((77037419 : вДЭ)/41779200000) := by
      push_cast
      nlinarith [hS1, hќЈ, hќЈ0]
    have hD0 : (0:вДЭ) вЙ§ ((1 : вДЭ)/8192) * (S1 + ((49 * 10 : вДХ) : вДЭ) * ќЈ) := by
      push_cast
      nlinarith [hS10, hќЈ0]
    have hTpos : (0:вДЭ) < 1 - 2 * ((1:вДЭ) * (((1 : вДЭ)/8192) * (S1 + ((49 * 10 : вДХ) : вДЭ) * ќЈ))) := by
      nlinarith [hD, hD0]
    rw [div_mul_eq_mul_div, div_le_iffвВА hTpos]
    have hRHS0 : (0:вДЭ) вЙ§ ((1 : вДЭ)/8192) * S2 / 4 := by
      have : (0:вДЭ) вЙ§ S2 := Finset.sum_nonneg fun _ _ => sq_nonneg _
      positivity
    nlinarith [hD, hD0, hS2, hTpos, hRHS0,
      mul_le_mul_of_nonneg_left hD hD0]

/-- **The drop is strictly positive**: the witness is misclassified, so
    `ќ£вИЗ¬≤ вЙ• ((1511461 : вДЭ)/332928)/4 > 0` and the loss strictly decreases. -/
theorem trained_linear_sgd_strictly_descends :
    crossEntropy 10 (dense (Mat.unflatten (Mat.flatten Wd -
        ((1 : вДЭ)/8192) вАҐ binary32.linearFloatGrad Wd bd xd Real.exp lblD)) bd xd)
        lblD <
      crossEntropy 10 (dense (Mat.unflatten (Mat.flatten Wd)) bd xd) lblD := by
  have h := trained_linear_sgd_descends_concrete
  have h2 := gradSq_lower
  linarith [h, h2]

end TrainedLinearDescent
end Proofs
