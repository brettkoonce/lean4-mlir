-- ── softmax facts at the trained logits (no `exp` is ever evaluated) ──

theorem sm_pos : ∀ j, 0 < softmax 10 (dense Wd bd xd) j := fun j =>
  div_pos (Real.exp_pos _)
    (Finset.sum_pos (fun _ _ => Real.exp_pos _) ⟨j, Finset.mem_univ j⟩)

theorem sm_sum : (∑ j, softmax 10 (dense Wd bd xd) j) = 1 := by
  show (∑ j, Real.exp (dense Wd bd xd j) / ∑ k, Real.exp (dense Wd bd xd k)) = 1
  simp only [div_eq_mul_inv, ← Finset.sum_mul]
  exact mul_inv_cancel₀ (ne_of_gt (Finset.sum_pos
    (fun k _ => Real.exp_pos _) ⟨lblD, Finset.mem_univ _⟩))

theorem sm_le_one : ∀ j, softmax 10 (dense Wd bd xd) j ≤ 1 := by
  intro j
  have h := Finset.single_le_sum
    (f := fun k => softmax 10 (dense Wd bd xd) k)
    (fun k _ => (sm_pos k).le) (Finset.mem_univ j)
  rw [sm_sum] at h
  exact h

/-- **Softmax at the true label ≤ 1/2** — from misclassification alone:
    `exp z_lbl ≤ exp z_c` and both terms sit inside the positive sum. -/
theorem sm_lbl_le_half : softmax 10 (dense Wd bd xd) lblD ≤ 1 / 2 := by
  have hee : Real.exp (dense Wd bd xd lblD) ≤ Real.exp (dense Wd bd xd cD) :=
    Real.exp_le_exp.mpr hz_lbl_le
  have hSpos : 0 < ∑ k, Real.exp (dense Wd bd xd k) :=
    Finset.sum_pos (fun k _ => Real.exp_pos _) ⟨lblD, Finset.mem_univ _⟩
  have hpair : Real.exp (dense Wd bd xd lblD) + Real.exp (dense Wd bd xd cD) ≤
      ∑ k, Real.exp (dense Wd bd xd k) := by
    have hsub := Finset.sum_le_sum_of_subset_of_nonneg
      (Finset.subset_univ ({lblD, cD} : Finset (Fin 10)))
      (fun k _ _ => (Real.exp_pos (dense Wd bd xd k)).le)
    rwa [Finset.sum_pair (by decide : lblD ≠ cD)] at hsub
  show Real.exp (dense Wd bd xd lblD) / (∑ k, Real.exp (dense Wd bd xd k)) ≤ 1 / 2
  rw [div_le_iff₀ hSpos]
  nlinarith [Real.exp_pos (dense Wd bd xd lblD)]

/-- `Σⱼ |softmaxⱼ − onehotⱼ| = 2(1 − softmax_lbl) ≤ 2`. -/
theorem sm_cot_l1 :
    (∑ j, |softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j|) ≤ 2 := by
  have hsplit := Finset.add_sum_erase Finset.univ
    (fun j => |softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j|)
    (Finset.mem_univ lblD)
  have hsplit1 := Finset.add_sum_erase Finset.univ
    (fun j => softmax 10 (dense Wd bd xd) j) (Finset.mem_univ lblD)
  rw [sm_sum] at hsplit1
  have herase : (∑ j ∈ Finset.univ.erase lblD,
      |softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j|) =
      ∑ j ∈ Finset.univ.erase lblD, softmax 10 (dense Wd bd xd) j := by
    refine Finset.sum_congr rfl fun j hj => ?_
    rw [show oneHot 10 lblD j = 0 from if_neg (Finset.mem_erase.mp hj).1,
        sub_zero, abs_of_pos (sm_pos j)]
  have hlbl : |softmax 10 (dense Wd bd xd) lblD - oneHot 10 lblD lblD| =
      1 - softmax 10 (dense Wd bd xd) lblD := by
    rw [show oneHot 10 lblD lblD = 1 from if_pos rfl,
        abs_of_nonpos (by linarith [sm_le_one lblD]), neg_sub]
  have hs := sm_pos lblD
  linarith [hsplit, hsplit1, herase, hlbl]

/-- `Σⱼ (softmaxⱼ − onehotⱼ)² ≥ 1/4` — the label term alone, via
    `softmax_lbl ≤ 1/2`. -/
theorem sm_cot_sq :
    (1 : ℝ) / 4 ≤ ∑ j, (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) ^ 2 := by
  have hterm : (1 : ℝ) / 4 ≤
      (softmax 10 (dense Wd bd xd) lblD - oneHot 10 lblD lblD) ^ 2 := by
    rw [show oneHot 10 lblD lblD = 1 from if_pos rfl]
    nlinarith [sm_lbl_le_half, (sm_pos lblD).le]
  exact hterm.trans (Finset.single_le_sum
    (f := fun j => (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) ^ 2)
    (fun j _ => sq_nonneg _) (Finset.mem_univ lblD))

