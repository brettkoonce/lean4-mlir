    (∑ idx, |gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx|) ≤ ((15367 : ℝ)/1020) := by
  rw [← finProdFinEquiv.sum_comp (fun idx => |gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx|)]
  rw [Fintype.sum_prod_type]
  simp_rw [grad_key]
  calc (∑ i : Fin 49, ∑ j : Fin 10,
        |xd i * (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j)|)
      = ∑ i : Fin 49, xd i * ∑ j : Fin 10,
          |softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j| := by
        refine Finset.sum_congr rfl fun i _ => ?_
        rw [Finset.mul_sum]
        refine Finset.sum_congr rfl fun j _ => ?_
        rw [abs_mul, abs_of_nonneg (xd_nonneg i)]
    _ ≤ ∑ i : Fin 49, xd i * 2 :=
        Finset.sum_le_sum fun i _ =>
          mul_le_mul_of_nonneg_left sm_cot_l1 (xd_nonneg i)
    _ = 2 * ∑ i, xd i := by
        rw [← Finset.sum_mul, mul_comm]
    _ = ((15367 : ℝ)/1020) := by rw [xd_sum]; norm_num

/-- `Σ(∇L)² ≥ ((1511461 : ℝ)/332928)/4` (= (Σxᵢ²)/4, exact). -/
theorem gradSq_lower :
    ((1511461 : ℝ)/332928) / 4 ≤ ∑ idx, gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx ^ 2 := by
  rw [← finProdFinEquiv.sum_comp (fun idx => gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx ^ 2)]
  rw [Fintype.sum_prod_type]
  simp_rw [grad_key]
  have hfac : (∑ i : Fin 49, ∑ j : Fin 10,
      (xd i * (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j)) ^ 2) =
      (∑ i, xd i ^ 2) * ∑ j : Fin 10,
        (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) ^ 2 := by
    rw [Finset.sum_mul]
    refine Finset.sum_congr rfl fun i _ => ?_
    rw [Finset.mul_sum]
    refine Finset.sum_congr rfl fun j _ => ?_
    ring
  rw [hfac]
  have hB0 : (0:ℝ) ≤ ∑ i, xd i ^ 2 := Finset.sum_nonneg fun i _ => sq_nonneg _
  calc ((1511461 : ℝ)/332928) / 4 = ((1511461 : ℝ)/332928) * (1/4) := by norm_num
    _ = (∑ i, xd i ^ 2) * (1/4) := by rw [xd_sq_sum]
    _ ≤ (∑ i, xd i ^ 2) * ∑ j : Fin 10,
        (softmax 10 (dense Wd bd xd) j - oneHot 10 lblD j) ^ 2 :=
        mul_le_mul_of_nonneg_left sm_cot_sq hB0

-- ── the float-side budgets, evaluated ──

/-- Float-forward drift: `denseErr` at `b = 0`, `e = 0`, evaluated exactly per
    class column — `((1+2⁻²⁴)⁵¹ − 1)·Σᵢ|Wᵢₖ|·|xᵢ| ≤ ((1 : ℝ)/25000)`. -/
theorem hdelta : ∀ k, |binary32.dense Wd bd xd k - dense Wd bd xd k| ≤
    ((1 : ℝ)/25000) := by
  intro k
  refine (binary32.dense_close_fresh Wd bd xd k).trans ?_
  simp only [FloatModel.denseErr, binary32_u]
  fin_cases k <;>
    · simp [Wd, xd, bd, Fin.sum_univ_succ]
      norm_num [u32]

theorem hrho : FloatModel.smRho binary32.u 0 10 < 1 := by
  simp only [FloatModel.smRho, binary32_u]
  norm_num [u32]

/-- The gradient-oracle budget `η = mulErr u32 1 1 0 (cotErr u32 0 δ 10)`,
    bounded by `((81 : ℝ)/1000000)` — the `exp(2δ)−1` term via the γ-form. -/
theorem heta : FloatModel.mulErr binary32.u 1 1 0
    (FloatModel.cotErr binary32.u 0 ((1 : ℝ)/25000) 10) ≤ ((81 : ℝ)/1000000) := by
  have hE : Real.exp (2 * ((1 : ℝ)/25000)) - 1 ≤ ((801 : ℝ)/10000000) :=
    (FloatModel.exp_sub_one_le (by norm_num)).trans (by norm_num)
  simp only [FloatModel.mulErr, FloatModel.cotErr, FloatModel.smErr,
    FloatModel.smKappa, FloatModel.smRho, binary32_u]
  norm_num [u32]
  nlinarith [hE]

theorem heta0 : 0 ≤ FloatModel.mulErr binary32.u 1 1 0
    (FloatModel.cotErr binary32.u 0 ((1 : ℝ)/25000) 10) := by
  have hE0 : (0:ℝ) ≤ Real.exp (2 * ((1 : ℝ)/25000)) - 1 := by
    nlinarith [Real.add_one_le_exp (2 * ((1 : ℝ)/25000))]
  simp only [FloatModel.mulErr, FloatModel.cotErr, FloatModel.smErr,
    FloatModel.smKappa, FloatModel.smRho, binary32_u]
  norm_num [u32]
  nlinarith [hE0]

-- ── the capstone ──

set_option maxRecDepth 8192 in
/-- **Descent at TRAINED weights.** One binary32 SGD step (lr = ((1 : ℝ)/8192)) on
    the trained linear classifier, at the misclassified witness, decreases
    the real cross-entropy by ≥ lr·‖∇L‖²/2 — every hypothesis of
    `linear_float_sgd_descends` discharged, the rounding model constructed
    (`rndP 23`), zero axioms. Retires the `W = 0` degeneracy caveat of
    `binary32_linear_sgd_descends_concrete`. -/
theorem trained_linear_sgd_descends_concrete :
    crossEntropy 10 (dense (Mat.unflatten (Mat.flatten Wd -
        ((1 : ℝ)/8192) • binary32.linearFloatGrad Wd bd xd Real.exp lblD)) bd xd)
        lblD ≤
      crossEntropy 10 (dense (Mat.unflatten (Mat.flatten Wd)) bd xd) lblD -
        ((1 : ℝ)/8192) * (∑ idx, gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx ^ 2) / 2 := by
  have hS1 := gradL1_le
  have hS2 := gradSq_lower
  have hS10 : (0:ℝ) ≤ ∑ idx, |gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx| :=
    Finset.sum_nonneg fun _ _ => abs_nonneg _
  have hη := heta
  have hη0 := heta0
  have hfexp : ∀ t, |Real.exp t - Real.exp t| ≤ (0:ℝ) * Real.exp t := by
    intro t; simp
  refine linear_float_sgd_descends binary32 Wd bd xd lblD Real.exp
    (lr := ((1 : ℝ)/8192)) (a := 1) (eexp := 0) (δ := ((1 : ℝ)/25000))
    (by norm_num) xd_le_one (by norm_num) le_rfl (by norm_num) (by norm_num)
    hfexp hrho hdelta ?_ ?_ ?_
  · -- hsmall
    push_cast
    nlinarith [hS1, hS10, hη, hη0]
  · -- h1
    push_cast
    nlinarith [hS1, hS2, hS10, hη, hη0]
  · -- h2
    set S1 := ∑ idx, |gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx| with hS1def
    set S2 := ∑ idx, gradAt (fun w => crossEntropy 10 (dense (Mat.unflatten w) bd xd) lblD)
        (Mat.flatten Wd) idx ^ 2 with hS2def
    set η := FloatModel.mulErr binary32.u 1 1 0
      (FloatModel.cotErr binary32.u 0 ((1 : ℝ)/25000) 10) with hηdef
    have hD : ((1 : ℝ)/8192) * (S1 + ((49 * 10 : ℕ) : ℝ) * η) ≤ ((77037419 : ℝ)/41779200000) := by
      push_cast
      nlinarith [hS1, hη, hη0]
    have hD0 : (0:ℝ) ≤ ((1 : ℝ)/8192) * (S1 + ((49 * 10 : ℕ) : ℝ) * η) := by
      push_cast
      nlinarith [hS10, hη0]
    have hTpos : (0:ℝ) < 1 - 2 * ((1:ℝ) * (((1 : ℝ)/8192) * (S1 + ((49 * 10 : ℕ) : ℝ) * η))) := by
      nlinarith [hD, hD0]
    rw [div_mul_eq_mul_div, div_le_iff₀ hTpos]
    have hRHS0 : (0:ℝ) ≤ ((1 : ℝ)/8192) * S2 / 4 := by
      have : (0:ℝ) ≤ S2 := Finset.sum_nonneg fun _ _ => sq_nonneg _
      positivity
    nlinarith [hD, hD0, hS2, hTpos, hRHS0,
      mul_le_mul_of_nonneg_left hD hD0]

/-- **The drop is strictly positive**: the witness is misclassified, so
    `Σ∇² ≥ ((1511461 : ℝ)/332928)/4 > 0` and the loss strictly decreases. -/
theorem trained_linear_sgd_strictly_descends :
    crossEntropy 10 (dense (Mat.unflatten (Mat.flatten Wd -
        ((1 : ℝ)/8192) • binary32.linearFloatGrad Wd bd xd Real.exp lblD)) bd xd)
        lblD <
      crossEntropy 10 (dense (Mat.unflatten (Mat.flatten Wd)) bd xd) lblD := by
  have h := trained_linear_sgd_descends_concrete
  have h2 := gradSq_lower
  linarith [h, h2]

end TrainedLinearDescent
end Proofs
