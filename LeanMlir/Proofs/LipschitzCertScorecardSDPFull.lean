theorem vP19SF_eq : ∀ t, vP19SF t = W2SF 1 t - W2SF 9 t := by
  intro t
  fin_cases t <;>
    · simp [vP19SF, W2SF]
      try norm_num

theorem tP19SF_nonneg : ∀ k, 0 ≤ tP19SF k := by
  intro k
  fin_cases k <;>
    · simp [tP19SF]
      try norm_num

theorem dP19SF_nonneg : ∀ i, 0 ≤ dP19SF i := by
  intro i
  fin_cases i <;>
    · simp [dP19SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P19SF : ∀ a b, smP19SF a b
    = 2 * (if a = b then tP19SF a else 0) - vP19SF a * vP19SF b
      - (1/((13180211 : ℝ)/1000000)) * (tP19SF a * (G1SF a b * tP19SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP19SF, tP19SF, vP19SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P19SF : ∀ a b, smP19SF a b = ∑ i, lP19SF a i * (dP19SF i * lP19SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP19SF, lP19SF, dP19SF, Fin.sum_univ_succ]
      try norm_num

theorem hS19SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP19SF k * z k) ^ 2
      + (1/((13180211 : ℝ)/1000000)) * (∑ a, ∑ b, (tP19SF a * z a) * (G1SF a b * (tP19SF b * z b)))
      ≤ 2 * ∑ k, tP19SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP19SF lP19SF vP19SF tP19SF dP19SF
    dP19SF_nonneg h1P19SF h2P19SF

theorem pairSqSF_1_9 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 1 - mlpSF u 9) - (mlpSF u' 1 - mlpSF u' 9)) ^ 2
      ≤ ((13180211 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 1 - mlpSF w 9
      = ∑ t, vP19SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 1 - mlpSF w 9
        = ∑ t, (W2SF 1 t - W2SF 9 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 1 9 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP19SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP19SF tP19SF tP19SF_nonneg (by norm_num)
    hS19SF u u'

