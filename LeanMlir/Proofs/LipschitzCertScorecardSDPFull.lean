theorem vP45SF_eq : ∀ t, vP45SF t = W2SF 4 t - W2SF 5 t := by
  intro t
  fin_cases t <;>
    · simp [vP45SF, W2SF]
      try norm_num

theorem tP45SF_nonneg : ∀ k, 0 ≤ tP45SF k := by
  intro k
  fin_cases k <;>
    · simp [tP45SF]
      try norm_num

theorem dP45SF_nonneg : ∀ i, 0 ≤ dP45SF i := by
  intro i
  fin_cases i <;>
    · simp [dP45SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P45SF : ∀ a b, smP45SF a b
    = 2 * (if a = b then tP45SF a else 0) - vP45SF a * vP45SF b
      - (1/((13113867 : ℝ)/1000000)) * (tP45SF a * (G1SF a b * tP45SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP45SF, tP45SF, vP45SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P45SF : ∀ a b, smP45SF a b = ∑ i, lP45SF a i * (dP45SF i * lP45SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP45SF, lP45SF, dP45SF, Fin.sum_univ_succ]
      try norm_num

theorem hS45SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP45SF k * z k) ^ 2
      + (1/((13113867 : ℝ)/1000000)) * (∑ a, ∑ b, (tP45SF a * z a) * (G1SF a b * (tP45SF b * z b)))
      ≤ 2 * ∑ k, tP45SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP45SF lP45SF vP45SF tP45SF dP45SF
    dP45SF_nonneg h1P45SF h2P45SF

theorem pairSqSF_4_5 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 4 - mlpSF u 5) - (mlpSF u' 4 - mlpSF u' 5)) ^ 2
      ≤ ((13113867 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 4 - mlpSF w 5
      = ∑ t, vP45SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 4 - mlpSF w 5
        = ∑ t, (W2SF 4 t - W2SF 5 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 4 5 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP45SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP45SF tP45SF tP45SF_nonneg (by norm_num)
    hS45SF u u'

