theorem vP47SF_eq : ∀ t, vP47SF t = W2SF 4 t - W2SF 7 t := by
  intro t
  fin_cases t <;>
    · simp [vP47SF, W2SF]
      try norm_num

theorem tP47SF_nonneg : ∀ k, 0 ≤ tP47SF k := by
  intro k
  fin_cases k <;>
    · simp [tP47SF]
      try norm_num

theorem dP47SF_nonneg : ∀ i, 0 ≤ dP47SF i := by
  intro i
  fin_cases i <;>
    · simp [dP47SF]
      try norm_num

