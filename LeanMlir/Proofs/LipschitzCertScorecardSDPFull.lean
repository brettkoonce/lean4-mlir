theorem vP08SF_eq : ∀ t, vP08SF t = W2SF 0 t - W2SF 8 t := by
  intro t
  fin_cases t <;>
    · simp [vP08SF, W2SF]
      try norm_num

theorem tP08SF_nonneg : ∀ k, 0 ≤ tP08SF k := by
  intro k
  fin_cases k <;>
    · simp [tP08SF]
      try norm_num

theorem dP08SF_nonneg : ∀ i, 0 ≤ dP08SF i := by
  intro i
  fin_cases i <;>
    · simp [dP08SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P08SF : ∀ a b, smP08SF a b
    = 2 * (if a = b then tP08SF a else 0) - vP08SF a * vP08SF b
      - (1/((9286091 : ℝ)/1000000)) * (tP08SF a * (G1SF a b * tP08SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP08SF, tP08SF, vP08SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P08SF : ∀ a b, smP08SF a b = ∑ i, lP08SF a i * (dP08SF i * lP08SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP08SF, lP08SF, dP08SF, Fin.sum_univ_succ]
      try norm_num

theorem hS08SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP08SF k * z k) ^ 2
      + (1/((9286091 : ℝ)/1000000)) * (∑ a, ∑ b, (tP08SF a * z a) * (G1SF a b * (tP08SF b * z b)))
      ≤ 2 * ∑ k, tP08SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP08SF lP08SF vP08SF tP08SF dP08SF
    dP08SF_nonneg h1P08SF h2P08SF

theorem pairSqSF_0_8 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 0 - mlpSF u 8) - (mlpSF u' 0 - mlpSF u' 8)) ^ 2
      ≤ ((9286091 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 0 - mlpSF w 8
      = ∑ t, vP08SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 0 - mlpSF w 8
        = ∑ t, (W2SF 0 t - W2SF 8 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 0 8 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP08SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP08SF tP08SF tP08SF_nonneg (by norm_num)
    hS08SF u u'

