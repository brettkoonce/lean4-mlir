theorem vP34SF_eq : ∀ t, vP34SF t = W2SF 3 t - W2SF 4 t := by
  intro t
  fin_cases t <;>
    · simp [vP34SF, W2SF]
      try norm_num

theorem tP34SF_nonneg : ∀ k, 0 ≤ tP34SF k := by
  intro k
  fin_cases k <;>
    · simp [tP34SF]
      try norm_num

theorem dP34SF_nonneg : ∀ i, 0 ≤ dP34SF i := by
  intro i
  fin_cases i <;>
    · simp [dP34SF]
      try norm_num

