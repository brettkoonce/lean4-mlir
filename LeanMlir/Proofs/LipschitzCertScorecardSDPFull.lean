theorem h1P34SF : ∀ a b, smP34SF a b
    = 2 * (if a = b then tP34SF a else 0) - vP34SF a * vP34SF b
      - (1/((8364997 : ℝ)/500000)) * (tP34SF a * (G1SF a b * tP34SF b)) := by
