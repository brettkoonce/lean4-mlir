  intro t
  fin_cases t <;>
    · simp [vP02SF, W2SF]
      try norm_num

theorem tP02SF_nonneg : ∀ k, 0 ≤ tP02SF k := by
  intro k
  fin_cases k <;>
    · simp [tP02SF]
      try norm_num

theorem dP02SF_nonneg : ∀ i, 0 ≤ dP02SF i := by
  intro i
  fin_cases i <;>
    · simp [dP02SF]
      try norm_num

