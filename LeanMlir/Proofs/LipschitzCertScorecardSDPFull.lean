theorem vP28SF_eq : ∀ t, vP28SF t = W2SF 2 t - W2SF 8 t := by
  intro t
  fin_cases t <;>
    · simp [vP28SF, W2SF]
      try norm_num

theorem tP28SF_nonneg : ∀ k, 0 ≤ tP28SF k := by
  intro k
  fin_cases k <;>
    · simp [tP28SF]
      try norm_num

theorem dP28SF_nonneg : ∀ i, 0 ≤ dP28SF i := by
  intro i
  fin_cases i <;>
    · simp [dP28SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P28SF : ∀ a b, smP28SF a b
    = 2 * (if a = b then tP28SF a else 0) - vP28SF a * vP28SF b
      - (1/((50357 : ℝ)/5000)) * (tP28SF a * (G1SF a b * tP28SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP28SF, tP28SF, vP28SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P28SF : ∀ a b, smP28SF a b = ∑ i, lP28SF a i * (dP28SF i * lP28SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP28SF, lP28SF, dP28SF, Fin.sum_univ_succ]
      try norm_num

theorem hS28SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP28SF k * z k) ^ 2
      + (1/((50357 : ℝ)/5000)) * (∑ a, ∑ b, (tP28SF a * z a) * (G1SF a b * (tP28SF b * z b)))
      ≤ 2 * ∑ k, tP28SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP28SF lP28SF vP28SF tP28SF dP28SF
    dP28SF_nonneg h1P28SF h2P28SF

theorem pairSqSF_2_8 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 2 - mlpSF u 8) - (mlpSF u' 2 - mlpSF u' 8)) ^ 2
      ≤ ((50357 : ℝ)/5000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 2 - mlpSF w 8
      = ∑ t, vP28SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 2 - mlpSF w 8
        = ∑ t, (W2SF 2 t - W2SF 8 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 2 8 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP28SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP28SF tP28SF tP28SF_nonneg (by norm_num)
    hS28SF u u'

