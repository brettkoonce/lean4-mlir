theorem vP26SF_eq : ∀ t, vP26SF t = W2SF 2 t - W2SF 6 t := by
  intro t
  fin_cases t <;>
    · simp [vP26SF, W2SF]
      try norm_num

theorem tP26SF_nonneg : ∀ k, 0 ≤ tP26SF k := by
  intro k
  fin_cases k <;>
    · simp [tP26SF]
      try norm_num

theorem dP26SF_nonneg : ∀ i, 0 ≤ dP26SF i := by
  intro i
  fin_cases i <;>
    · simp [dP26SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P26SF : ∀ a b, smP26SF a b
    = 2 * (if a = b then tP26SF a else 0) - vP26SF a * vP26SF b
      - (1/((11863477 : ℝ)/1000000)) * (tP26SF a * (G1SF a b * tP26SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP26SF, tP26SF, vP26SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P26SF : ∀ a b, smP26SF a b = ∑ i, lP26SF a i * (dP26SF i * lP26SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP26SF, lP26SF, dP26SF, Fin.sum_univ_succ]
      try norm_num

theorem hS26SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP26SF k * z k) ^ 2
      + (1/((11863477 : ℝ)/1000000)) * (∑ a, ∑ b, (tP26SF a * z a) * (G1SF a b * (tP26SF b * z b)))
      ≤ 2 * ∑ k, tP26SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP26SF lP26SF vP26SF tP26SF dP26SF
    dP26SF_nonneg h1P26SF h2P26SF

theorem pairSqSF_2_6 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 2 - mlpSF u 6) - (mlpSF u' 2 - mlpSF u' 6)) ^ 2
      ≤ ((11863477 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 2 - mlpSF w 6
      = ∑ t, vP26SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 2 - mlpSF w 6
        = ∑ t, (W2SF 2 t - W2SF 6 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 2 6 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP26SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP26SF tP26SF tP26SF_nonneg (by norm_num)
    hS26SF u u'

