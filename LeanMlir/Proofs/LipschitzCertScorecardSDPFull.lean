theorem vP05SF_eq : ∀ t, vP05SF t = W2SF 0 t - W2SF 5 t := by
  intro t
  fin_cases t <;>
    · simp [vP05SF, W2SF]
      try norm_num

theorem tP05SF_nonneg : ∀ k, 0 ≤ tP05SF k := by
  intro k
  fin_cases k <;>
    · simp [tP05SF]
      try norm_num

theorem dP05SF_nonneg : ∀ i, 0 ≤ dP05SF i := by
  intro i
  fin_cases i <;>
    · simp [dP05SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P05SF : ∀ a b, smP05SF a b
    = 2 * (if a = b then tP05SF a else 0) - vP05SF a * vP05SF b
      - (1/((7740489 : ℝ)/1000000)) * (tP05SF a * (G1SF a b * tP05SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP05SF, tP05SF, vP05SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P05SF : ∀ a b, smP05SF a b = ∑ i, lP05SF a i * (dP05SF i * lP05SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP05SF, lP05SF, dP05SF, Fin.sum_univ_succ]
      try norm_num

theorem hS05SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP05SF k * z k) ^ 2
      + (1/((7740489 : ℝ)/1000000)) * (∑ a, ∑ b, (tP05SF a * z a) * (G1SF a b * (tP05SF b * z b)))
      ≤ 2 * ∑ k, tP05SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP05SF lP05SF vP05SF tP05SF dP05SF
    dP05SF_nonneg h1P05SF h2P05SF

theorem pairSqSF_0_5 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 0 - mlpSF u 5) - (mlpSF u' 0 - mlpSF u' 5)) ^ 2
      ≤ ((7740489 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 0 - mlpSF w 5
      = ∑ t, vP05SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 0 - mlpSF w 5
        = ∑ t, (W2SF 0 t - W2SF 5 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 0 5 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP05SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP05SF tP05SF tP05SF_nonneg (by norm_num)
    hS05SF u u'

