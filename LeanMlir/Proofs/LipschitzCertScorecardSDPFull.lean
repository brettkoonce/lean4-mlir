theorem vP17SF_eq : ∀ t, vP17SF t = W2SF 1 t - W2SF 7 t := by
  intro t
  fin_cases t <;>
    · simp [vP17SF, W2SF]
      try norm_num

theorem tP17SF_nonneg : ∀ k, 0 ≤ tP17SF k := by
  intro k
  fin_cases k <;>
    · simp [tP17SF]
      try norm_num

theorem dP17SF_nonneg : ∀ i, 0 ≤ dP17SF i := by
  intro i
  fin_cases i <;>
    · simp [dP17SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P17SF : ∀ a b, smP17SF a b
    = 2 * (if a = b then tP17SF a else 0) - vP17SF a * vP17SF b
      - (1/((7644743 : ℝ)/500000)) * (tP17SF a * (G1SF a b * tP17SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP17SF, tP17SF, vP17SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P17SF : ∀ a b, smP17SF a b = ∑ i, lP17SF a i * (dP17SF i * lP17SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP17SF, lP17SF, dP17SF, Fin.sum_univ_succ]
      try norm_num

theorem hS17SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP17SF k * z k) ^ 2
      + (1/((7644743 : ℝ)/500000)) * (∑ a, ∑ b, (tP17SF a * z a) * (G1SF a b * (tP17SF b * z b)))
      ≤ 2 * ∑ k, tP17SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP17SF lP17SF vP17SF tP17SF dP17SF
    dP17SF_nonneg h1P17SF h2P17SF

theorem pairSqSF_1_7 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 1 - mlpSF u 7) - (mlpSF u' 1 - mlpSF u' 7)) ^ 2
      ≤ ((7644743 : ℝ)/500000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 1 - mlpSF w 7
      = ∑ t, vP17SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 1 - mlpSF w 7
        = ∑ t, (W2SF 1 t - W2SF 7 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 1 7 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP17SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP17SF tP17SF tP17SF_nonneg (by norm_num)
    hS17SF u u'

