theorem vP79SF_eq : ∀ t, vP79SF t = W2SF 7 t - W2SF 9 t := by
  intro t
  fin_cases t <;>
    · simp [vP79SF, W2SF]
      try norm_num

theorem tP79SF_nonneg : ∀ k, 0 ≤ tP79SF k := by
  intro k
  fin_cases k <;>
    · simp [tP79SF]
      try norm_num

theorem dP79SF_nonneg : ∀ i, 0 ≤ dP79SF i := by
  intro i
  fin_cases i <;>
    · simp [dP79SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P79SF : ∀ a b, smP79SF a b
    = 2 * (if a = b then tP79SF a else 0) - vP79SF a * vP79SF b
      - (1/((4375987 : ℝ)/500000)) * (tP79SF a * (G1SF a b * tP79SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP79SF, tP79SF, vP79SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P79SF : ∀ a b, smP79SF a b = ∑ i, lP79SF a i * (dP79SF i * lP79SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP79SF, lP79SF, dP79SF, Fin.sum_univ_succ]
      try norm_num

theorem hS79SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP79SF k * z k) ^ 2
      + (1/((4375987 : ℝ)/500000)) * (∑ a, ∑ b, (tP79SF a * z a) * (G1SF a b * (tP79SF b * z b)))
      ≤ 2 * ∑ k, tP79SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP79SF lP79SF vP79SF tP79SF dP79SF
    dP79SF_nonneg h1P79SF h2P79SF

theorem pairSqSF_7_9 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 7 - mlpSF u 9) - (mlpSF u' 7 - mlpSF u' 9)) ^ 2
      ≤ ((4375987 : ℝ)/500000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 7 - mlpSF w 9
      = ∑ t, vP79SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 7 - mlpSF w 9
        = ∑ t, (W2SF 7 t - W2SF 9 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 7 9 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP79SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP79SF tP79SF tP79SF_nonneg (by norm_num)
    hS79SF u u'

