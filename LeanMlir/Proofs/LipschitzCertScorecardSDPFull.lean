theorem vP01SF_eq : ∀ t, vP01SF t = W2SF 0 t - W2SF 1 t := by
  intro t
  fin_cases t <;>
    · simp [vP01SF, W2SF]
      try norm_num

theorem tP01SF_nonneg : ∀ k, 0 ≤ tP01SF k := by
  intro k
  fin_cases k <;>
    · simp [tP01SF]
      try norm_num

theorem dP01SF_nonneg : ∀ i, 0 ≤ dP01SF i := by
  intro i
  fin_cases i <;>
    · simp [dP01SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P01SF : ∀ a b, smP01SF a b
    = 2 * (if a = b then tP01SF a else 0) - vP01SF a * vP01SF b
      - (1/((474273 : ℝ)/31250)) * (tP01SF a * (G1SF a b * tP01SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP01SF, tP01SF, vP01SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P01SF : ∀ a b, smP01SF a b = ∑ i, lP01SF a i * (dP01SF i * lP01SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP01SF, lP01SF, dP01SF, Fin.sum_univ_succ]
      try norm_num

theorem hS01SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP01SF k * z k) ^ 2
      + (1/((474273 : ℝ)/31250)) * (∑ a, ∑ b, (tP01SF a * z a) * (G1SF a b * (tP01SF b * z b)))
      ≤ 2 * ∑ k, tP01SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP01SF lP01SF vP01SF tP01SF dP01SF
    dP01SF_nonneg h1P01SF h2P01SF

theorem pairSqSF_0_1 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 0 - mlpSF u 1) - (mlpSF u' 0 - mlpSF u' 1)) ^ 2
      ≤ ((474273 : ℝ)/31250) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 0 - mlpSF w 1
      = ∑ t, vP01SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 0 - mlpSF w 1
        = ∑ t, (W2SF 0 t - W2SF 1 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 0 1 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP01SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP01SF tP01SF tP01SF_nonneg (by norm_num)
    hS01SF u u'

