    ((mlpSF u 6 - mlpSF u 8) - (mlpSF u' 6 - mlpSF u' 8)) ^ 2
      ≤ ((2347189 : ℝ)/250000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 6 - mlpSF w 8
      = ∑ t, vP68SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 6 - mlpSF w 8
        = ∑ t, (W2SF 6 t - W2SF 8 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 6 8 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP68SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP68SF tP68SF tP68SF_nonneg (by norm_num)
    hS68SF u u'

