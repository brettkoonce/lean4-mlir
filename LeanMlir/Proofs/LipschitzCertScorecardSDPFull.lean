theorem vP12SF_eq : ∀ t, vP12SF t = W2SF 1 t - W2SF 2 t := by
  intro t
  fin_cases t <;>
    · simp [vP12SF, W2SF]
      try norm_num

theorem tP12SF_nonneg : ∀ k, 0 ≤ tP12SF k := by
  intro k
  fin_cases k <;>
    · simp [tP12SF]
      try norm_num

theorem dP12SF_nonneg : ∀ i, 0 ≤ dP12SF i := by
  intro i
  fin_cases i <;>
    · simp [dP12SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P12SF : ∀ a b, smP12SF a b
    = 2 * (if a = b then tP12SF a else 0) - vP12SF a * vP12SF b
      - (1/((5117113 : ℝ)/500000)) * (tP12SF a * (G1SF a b * tP12SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP12SF, tP12SF, vP12SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P12SF : ∀ a b, smP12SF a b = ∑ i, lP12SF a i * (dP12SF i * lP12SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP12SF, lP12SF, dP12SF, Fin.sum_univ_succ]
      try norm_num

theorem hS12SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP12SF k * z k) ^ 2
      + (1/((5117113 : ℝ)/500000)) * (∑ a, ∑ b, (tP12SF a * z a) * (G1SF a b * (tP12SF b * z b)))
      ≤ 2 * ∑ k, tP12SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP12SF lP12SF vP12SF tP12SF dP12SF
    dP12SF_nonneg h1P12SF h2P12SF

theorem pairSqSF_1_2 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 1 - mlpSF u 2) - (mlpSF u' 1 - mlpSF u' 2)) ^ 2
      ≤ ((5117113 : ℝ)/500000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 1 - mlpSF w 2
      = ∑ t, vP12SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 1 - mlpSF w 2
        = ∑ t, (W2SF 1 t - W2SF 2 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 1 2 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP12SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP12SF tP12SF tP12SF_nonneg (by norm_num)
    hS12SF u u'

