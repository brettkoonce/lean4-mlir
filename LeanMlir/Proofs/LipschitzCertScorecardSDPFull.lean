theorem vP37SF_eq : ∀ t, vP37SF t = W2SF 3 t - W2SF 7 t := by
  intro t
  fin_cases t <;>
    · simp [vP37SF, W2SF]
      try norm_num

theorem tP37SF_nonneg : ∀ k, 0 ≤ tP37SF k := by
  intro k
  fin_cases k <;>
    · simp [tP37SF]
      try norm_num

theorem dP37SF_nonneg : ∀ i, 0 ≤ dP37SF i := by
  intro i
  fin_cases i <;>
    · simp [dP37SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P37SF : ∀ a b, smP37SF a b
    = 2 * (if a = b then tP37SF a else 0) - vP37SF a * vP37SF b
      - (1/((9478149 : ℝ)/1000000)) * (tP37SF a * (G1SF a b * tP37SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP37SF, tP37SF, vP37SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P37SF : ∀ a b, smP37SF a b = ∑ i, lP37SF a i * (dP37SF i * lP37SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP37SF, lP37SF, dP37SF, Fin.sum_univ_succ]
      try norm_num

theorem hS37SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP37SF k * z k) ^ 2
      + (1/((9478149 : ℝ)/1000000)) * (∑ a, ∑ b, (tP37SF a * z a) * (G1SF a b * (tP37SF b * z b)))
      ≤ 2 * ∑ k, tP37SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP37SF lP37SF vP37SF tP37SF dP37SF
    dP37SF_nonneg h1P37SF h2P37SF

theorem pairSqSF_3_7 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 3 - mlpSF u 7) - (mlpSF u' 3 - mlpSF u' 7)) ^ 2
      ≤ ((9478149 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 3 - mlpSF w 7
      = ∑ t, vP37SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 3 - mlpSF w 7
        = ∑ t, (W2SF 3 t - W2SF 7 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 3 7 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP37SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP37SF tP37SF tP37SF_nonneg (by norm_num)
    hS37SF u u'

