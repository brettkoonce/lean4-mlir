theorem vP16SF_eq : ∀ t, vP16SF t = W2SF 1 t - W2SF 6 t := by
  intro t
  fin_cases t <;>
    · simp [vP16SF, W2SF]
      try norm_num

theorem tP16SF_nonneg : ∀ k, 0 ≤ tP16SF k := by
  intro k
  fin_cases k <;>
    · simp [tP16SF]
      try norm_num

theorem dP16SF_nonneg : ∀ i, 0 ≤ dP16SF i := by
  intro i
  fin_cases i <;>
    · simp [dP16SF]
      try norm_num

