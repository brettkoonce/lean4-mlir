theorem h1P59SF : ∀ a b, smP59SF a b
    = 2 * (if a = b then tP59SF a else 0) - vP59SF a * vP59SF b
      - (1/((6274379 : ℝ)/500000)) * (tP59SF a * (G1SF a b * tP59SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP59SF, tP59SF, vP59SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P59SF : ∀ a b, smP59SF a b = ∑ i, lP59SF a i * (dP59SF i * lP59SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP59SF, lP59SF, dP59SF, Fin.sum_univ_succ]
