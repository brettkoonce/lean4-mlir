theorem h1P47SF : ∀ a b, smP47SF a b
    = 2 * (if a = b then tP47SF a else 0) - vP47SF a * vP47SF b
      - (1/((15052599 : ℝ)/1000000)) * (tP47SF a * (G1SF a b * tP47SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP47SF, tP47SF, vP47SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P47SF : ∀ a b, smP47SF a b = ∑ i, lP47SF a i * (dP47SF i * lP47SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP47SF, lP47SF, dP47SF, Fin.sum_univ_succ]
      try norm_num

theorem hS47SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP47SF k * z k) ^ 2
      + (1/((15052599 : ℝ)/1000000)) * (∑ a, ∑ b, (tP47SF a * z a) * (G1SF a b * (tP47SF b * z b)))
      ≤ 2 * ∑ k, tP47SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP47SF lP47SF vP47SF tP47SF dP47SF
    dP47SF_nonneg h1P47SF h2P47SF

theorem pairSqSF_4_7 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 4 - mlpSF u 7) - (mlpSF u' 4 - mlpSF u' 7)) ^ 2
      ≤ ((15052599 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 4 - mlpSF w 7
      = ∑ t, vP47SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 4 - mlpSF w 7
        = ∑ t, (W2SF 4 t - W2SF 7 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 4 7 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP47SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP47SF tP47SF tP47SF_nonneg (by norm_num)
    hS47SF u u'

