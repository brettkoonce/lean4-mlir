theorem vP04SF_eq : ∀ t, vP04SF t = W2SF 0 t - W2SF 4 t := by
  intro t
  fin_cases t <;>
    · simp [vP04SF, W2SF]
      try norm_num

theorem tP04SF_nonneg : ∀ k, 0 ≤ tP04SF k := by
  intro k
  fin_cases k <;>
    · simp [tP04SF]
      try norm_num

theorem dP04SF_nonneg : ∀ i, 0 ≤ dP04SF i := by
  intro i
  fin_cases i <;>
    · simp [dP04SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P04SF : ∀ a b, smP04SF a b
    = 2 * (if a = b then tP04SF a else 0) - vP04SF a * vP04SF b
      - (1/((13570687 : ℝ)/1000000)) * (tP04SF a * (G1SF a b * tP04SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP04SF, tP04SF, vP04SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P04SF : ∀ a b, smP04SF a b = ∑ i, lP04SF a i * (dP04SF i * lP04SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP04SF, lP04SF, dP04SF, Fin.sum_univ_succ]
      try norm_num

theorem hS04SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP04SF k * z k) ^ 2
      + (1/((13570687 : ℝ)/1000000)) * (∑ a, ∑ b, (tP04SF a * z a) * (G1SF a b * (tP04SF b * z b)))
      ≤ 2 * ∑ k, tP04SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP04SF lP04SF vP04SF tP04SF dP04SF
    dP04SF_nonneg h1P04SF h2P04SF

theorem pairSqSF_0_4 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 0 - mlpSF u 4) - (mlpSF u' 0 - mlpSF u' 4)) ^ 2
      ≤ ((13570687 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 0 - mlpSF w 4
      = ∑ t, vP04SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 0 - mlpSF w 4
        = ∑ t, (W2SF 0 t - W2SF 4 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 0 4 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP04SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP04SF tP04SF tP04SF_nonneg (by norm_num)
    hS04SF u u'

