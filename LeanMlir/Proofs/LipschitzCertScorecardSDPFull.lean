theorem vP49SF_eq : ∀ t, vP49SF t = W2SF 4 t - W2SF 9 t := by
  intro t
  fin_cases t <;>
    · simp [vP49SF, W2SF]
      try norm_num

theorem tP49SF_nonneg : ∀ k, 0 ≤ tP49SF k := by
  intro k
  fin_cases k <;>
    · simp [tP49SF]
      try norm_num

theorem dP49SF_nonneg : ∀ i, 0 ≤ dP49SF i := by
  intro i
  fin_cases i <;>
    · simp [dP49SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P49SF : ∀ a b, smP49SF a b
    = 2 * (if a = b then tP49SF a else 0) - vP49SF a * vP49SF b
      - (1/((1117211 : ℝ)/125000)) * (tP49SF a * (G1SF a b * tP49SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP49SF, tP49SF, vP49SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P49SF : ∀ a b, smP49SF a b = ∑ i, lP49SF a i * (dP49SF i * lP49SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP49SF, lP49SF, dP49SF, Fin.sum_univ_succ]
      try norm_num

theorem hS49SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP49SF k * z k) ^ 2
      + (1/((1117211 : ℝ)/125000)) * (∑ a, ∑ b, (tP49SF a * z a) * (G1SF a b * (tP49SF b * z b)))
      ≤ 2 * ∑ k, tP49SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP49SF lP49SF vP49SF tP49SF dP49SF
    dP49SF_nonneg h1P49SF h2P49SF

theorem pairSqSF_4_9 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 4 - mlpSF u 9) - (mlpSF u' 4 - mlpSF u' 9)) ^ 2
      ≤ ((1117211 : ℝ)/125000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 4 - mlpSF w 9
      = ∑ t, vP49SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 4 - mlpSF w 9
        = ∑ t, (W2SF 4 t - W2SF 9 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 4 9 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP49SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP49SF tP49SF tP49SF_nonneg (by norm_num)
    hS49SF u u'

