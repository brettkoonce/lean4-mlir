    (∑ k, vP02SF k * z k) ^ 2
      + (1/((9169829 : ℝ)/1000000)) * (∑ a, ∑ b, (tP02SF a * z a) * (G1SF a b * (tP02SF b * z b)))
      ≤ 2 * ∑ k, tP02SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP02SF lP02SF vP02SF tP02SF dP02SF
    dP02SF_nonneg h1P02SF h2P02SF

