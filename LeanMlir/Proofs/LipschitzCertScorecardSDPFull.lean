theorem h1P46SF : ∀ a b, smP46SF a b
    = 2 * (if a = b then tP46SF a else 0) - vP46SF a * vP46SF b
      - (1/((8721817 : ℝ)/1000000)) * (tP46SF a * (G1SF a b * tP46SF b)) := by
