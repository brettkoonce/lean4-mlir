theorem vP56SF_eq : ∀ t, vP56SF t = W2SF 5 t - W2SF 6 t := by
  intro t
  fin_cases t <;>
    · simp [vP56SF, W2SF]
      try norm_num

theorem tP56SF_nonneg : ∀ k, 0 ≤ tP56SF k := by
  intro k
  fin_cases k <;>
    · simp [tP56SF]
      try norm_num

theorem dP56SF_nonneg : ∀ i, 0 ≤ dP56SF i := by
  intro i
  fin_cases i <;>
    · simp [dP56SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P56SF : ∀ a b, smP56SF a b
    = 2 * (if a = b then tP56SF a else 0) - vP56SF a * vP56SF b
      - (1/((12699069 : ℝ)/1000000)) * (tP56SF a * (G1SF a b * tP56SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP56SF, tP56SF, vP56SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P56SF : ∀ a b, smP56SF a b = ∑ i, lP56SF a i * (dP56SF i * lP56SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP56SF, lP56SF, dP56SF, Fin.sum_univ_succ]
      try norm_num

theorem hS56SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP56SF k * z k) ^ 2
      + (1/((12699069 : ℝ)/1000000)) * (∑ a, ∑ b, (tP56SF a * z a) * (G1SF a b * (tP56SF b * z b)))
      ≤ 2 * ∑ k, tP56SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP56SF lP56SF vP56SF tP56SF dP56SF
    dP56SF_nonneg h1P56SF h2P56SF

theorem pairSqSF_5_6 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 5 - mlpSF u 6) - (mlpSF u' 5 - mlpSF u' 6)) ^ 2
      ≤ ((12699069 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 5 - mlpSF w 6
      = ∑ t, vP56SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 5 - mlpSF w 6
        = ∑ t, (W2SF 5 t - W2SF 6 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 5 6 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP56SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP56SF tP56SF tP56SF_nonneg (by norm_num)
    hS56SF u u'

