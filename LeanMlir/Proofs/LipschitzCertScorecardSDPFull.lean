theorem vP23SF_eq : ∀ t, vP23SF t = W2SF 2 t - W2SF 3 t := by
  intro t
  fin_cases t <;>
    · simp [vP23SF, W2SF]
      try norm_num

theorem tP23SF_nonneg : ∀ k, 0 ≤ tP23SF k := by
  intro k
  fin_cases k <;>
    · simp [tP23SF]
      try norm_num

theorem dP23SF_nonneg : ∀ i, 0 ≤ dP23SF i := by
  intro i
  fin_cases i <;>
    · simp [dP23SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P23SF : ∀ a b, smP23SF a b
    = 2 * (if a = b then tP23SF a else 0) - vP23SF a * vP23SF b
      - (1/((225513 : ℝ)/31250)) * (tP23SF a * (G1SF a b * tP23SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP23SF, tP23SF, vP23SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P23SF : ∀ a b, smP23SF a b = ∑ i, lP23SF a i * (dP23SF i * lP23SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP23SF, lP23SF, dP23SF, Fin.sum_univ_succ]
      try norm_num

theorem hS23SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP23SF k * z k) ^ 2
      + (1/((225513 : ℝ)/31250)) * (∑ a, ∑ b, (tP23SF a * z a) * (G1SF a b * (tP23SF b * z b)))
      ≤ 2 * ∑ k, tP23SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP23SF lP23SF vP23SF tP23SF dP23SF
    dP23SF_nonneg h1P23SF h2P23SF

theorem pairSqSF_2_3 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 2 - mlpSF u 3) - (mlpSF u' 2 - mlpSF u' 3)) ^ 2
      ≤ ((225513 : ℝ)/31250) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 2 - mlpSF w 3
      = ∑ t, vP23SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 2 - mlpSF w 3
        = ∑ t, (W2SF 2 t - W2SF 3 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 2 3 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP23SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP23SF tP23SF tP23SF_nonneg (by norm_num)
    hS23SF u u'

