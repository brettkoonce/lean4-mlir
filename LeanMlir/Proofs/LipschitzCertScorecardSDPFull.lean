theorem vP36SF_eq : ∀ t, vP36SF t = W2SF 3 t - W2SF 6 t := by
  intro t
  fin_cases t <;>
    · simp [vP36SF, W2SF]
      try norm_num

theorem tP36SF_nonneg : ∀ k, 0 ≤ tP36SF k := by
  intro k
  fin_cases k <;>
    · simp [tP36SF]
      try norm_num

theorem dP36SF_nonneg : ∀ i, 0 ≤ dP36SF i := by
  intro i
  fin_cases i <;>
    · simp [dP36SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P36SF : ∀ a b, smP36SF a b
    = 2 * (if a = b then tP36SF a else 0) - vP36SF a * vP36SF b
      - (1/((14905841 : ℝ)/1000000)) * (tP36SF a * (G1SF a b * tP36SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP36SF, tP36SF, vP36SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P36SF : ∀ a b, smP36SF a b = ∑ i, lP36SF a i * (dP36SF i * lP36SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP36SF, lP36SF, dP36SF, Fin.sum_univ_succ]
      try norm_num

theorem hS36SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP36SF k * z k) ^ 2
      + (1/((14905841 : ℝ)/1000000)) * (∑ a, ∑ b, (tP36SF a * z a) * (G1SF a b * (tP36SF b * z b)))
      ≤ 2 * ∑ k, tP36SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP36SF lP36SF vP36SF tP36SF dP36SF
    dP36SF_nonneg h1P36SF h2P36SF

theorem pairSqSF_3_6 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 3 - mlpSF u 6) - (mlpSF u' 3 - mlpSF u' 6)) ^ 2
      ≤ ((14905841 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 3 - mlpSF w 6
      = ∑ t, vP36SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 3 - mlpSF w 6
        = ∑ t, (W2SF 3 t - W2SF 6 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 3 6 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP36SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP36SF tP36SF tP36SF_nonneg (by norm_num)
    hS36SF u u'

