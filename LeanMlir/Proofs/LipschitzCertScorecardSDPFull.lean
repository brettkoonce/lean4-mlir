theorem vP89SF_eq : ∀ t, vP89SF t = W2SF 8 t - W2SF 9 t := by
  intro t
  fin_cases t <;>
    · simp [vP89SF, W2SF]
      try norm_num

theorem tP89SF_nonneg : ∀ k, 0 ≤ tP89SF k := by
  intro k
  fin_cases k <;>
    · simp [tP89SF]
      try norm_num

theorem dP89SF_nonneg : ∀ i, 0 ≤ dP89SF i := by
  intro i
  fin_cases i <;>
    · simp [dP89SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P89SF : ∀ a b, smP89SF a b
    = 2 * (if a = b then tP89SF a else 0) - vP89SF a * vP89SF b
      - (1/((2295311 : ℝ)/250000)) * (tP89SF a * (G1SF a b * tP89SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP89SF, tP89SF, vP89SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P89SF : ∀ a b, smP89SF a b = ∑ i, lP89SF a i * (dP89SF i * lP89SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP89SF, lP89SF, dP89SF, Fin.sum_univ_succ]
      try norm_num

theorem hS89SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP89SF k * z k) ^ 2
      + (1/((2295311 : ℝ)/250000)) * (∑ a, ∑ b, (tP89SF a * z a) * (G1SF a b * (tP89SF b * z b)))
      ≤ 2 * ∑ k, tP89SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP89SF lP89SF vP89SF tP89SF dP89SF
    dP89SF_nonneg h1P89SF h2P89SF

theorem pairSqSF_8_9 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 8 - mlpSF u 9) - (mlpSF u' 8 - mlpSF u' 9)) ^ 2
      ≤ ((2295311 : ℝ)/250000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 8 - mlpSF w 9
      = ∑ t, vP89SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 8 - mlpSF w 9
        = ∑ t, (W2SF 8 t - W2SF 9 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 8 9 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP89SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP89SF tP89SF tP89SF_nonneg (by norm_num)
    hS89SF u u'

