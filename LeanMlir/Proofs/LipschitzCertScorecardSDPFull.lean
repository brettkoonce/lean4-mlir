theorem vP25SF_eq : ∀ t, vP25SF t = W2SF 2 t - W2SF 5 t := by
  intro t
  fin_cases t <;>
    · simp [vP25SF, W2SF]
      try norm_num

theorem tP25SF_nonneg : ∀ k, 0 ≤ tP25SF k := by
  intro k
  fin_cases k <;>
    · simp [tP25SF]
      try norm_num

theorem dP25SF_nonneg : ∀ i, 0 ≤ dP25SF i := by
  intro i
  fin_cases i <;>
    · simp [dP25SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P25SF : ∀ a b, smP25SF a b
    = 2 * (if a = b then tP25SF a else 0) - vP25SF a * vP25SF b
      - (1/((13407663 : ℝ)/1000000)) * (tP25SF a * (G1SF a b * tP25SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP25SF, tP25SF, vP25SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P25SF : ∀ a b, smP25SF a b = ∑ i, lP25SF a i * (dP25SF i * lP25SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP25SF, lP25SF, dP25SF, Fin.sum_univ_succ]
      try norm_num

theorem hS25SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP25SF k * z k) ^ 2
      + (1/((13407663 : ℝ)/1000000)) * (∑ a, ∑ b, (tP25SF a * z a) * (G1SF a b * (tP25SF b * z b)))
      ≤ 2 * ∑ k, tP25SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP25SF lP25SF vP25SF tP25SF dP25SF
    dP25SF_nonneg h1P25SF h2P25SF

theorem pairSqSF_2_5 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 2 - mlpSF u 5) - (mlpSF u' 2 - mlpSF u' 5)) ^ 2
      ≤ ((13407663 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 2 - mlpSF w 5
      = ∑ t, vP25SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 2 - mlpSF w 5
        = ∑ t, (W2SF 2 t - W2SF 5 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 2 5 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP25SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP25SF tP25SF tP25SF_nonneg (by norm_num)
    hS25SF u u'

