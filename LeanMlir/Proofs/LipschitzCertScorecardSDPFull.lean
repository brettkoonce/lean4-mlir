theorem vP57SF_eq : ∀ t, vP57SF t = W2SF 5 t - W2SF 7 t := by
  intro t
  fin_cases t <;>
    · simp [vP57SF, W2SF]
      try norm_num

theorem tP57SF_nonneg : ∀ k, 0 ≤ tP57SF k := by
  intro k
  fin_cases k <;>
    · simp [tP57SF]
      try norm_num

theorem dP57SF_nonneg : ∀ i, 0 ≤ dP57SF i := by
  intro i
  fin_cases i <;>
    · simp [dP57SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P57SF : ∀ a b, smP57SF a b
    = 2 * (if a = b then tP57SF a else 0) - vP57SF a * vP57SF b
      - (1/((1927603 : ℝ)/125000)) * (tP57SF a * (G1SF a b * tP57SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP57SF, tP57SF, vP57SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P57SF : ∀ a b, smP57SF a b = ∑ i, lP57SF a i * (dP57SF i * lP57SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP57SF, lP57SF, dP57SF, Fin.sum_univ_succ]
      try norm_num

theorem hS57SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP57SF k * z k) ^ 2
      + (1/((1927603 : ℝ)/125000)) * (∑ a, ∑ b, (tP57SF a * z a) * (G1SF a b * (tP57SF b * z b)))
      ≤ 2 * ∑ k, tP57SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP57SF lP57SF vP57SF tP57SF dP57SF
    dP57SF_nonneg h1P57SF h2P57SF

theorem pairSqSF_5_7 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 5 - mlpSF u 7) - (mlpSF u' 5 - mlpSF u' 7)) ^ 2
      ≤ ((1927603 : ℝ)/125000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 5 - mlpSF w 7
      = ∑ t, vP57SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 5 - mlpSF w 7
        = ∑ t, (W2SF 5 t - W2SF 7 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 5 7 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP57SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP57SF tP57SF tP57SF_nonneg (by norm_num)
    hS57SF u u'

