  intro t
  fin_cases t <;>
    · simp [vP09SF, W2SF]
      try norm_num

theorem tP09SF_nonneg : ∀ k, 0 ≤ tP09SF k := by
  intro k
  fin_cases k <;>
    · simp [tP09SF]
      try norm_num

theorem dP09SF_nonneg : ∀ i, 0 ≤ dP09SF i := by
  intro i
  fin_cases i <;>
    · simp [dP09SF]
      try norm_num

