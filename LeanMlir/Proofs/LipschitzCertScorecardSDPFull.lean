theorem vP13SF_eq : ∀ t, vP13SF t = W2SF 1 t - W2SF 3 t := by
  intro t
  fin_cases t <;>
    · simp [vP13SF, W2SF]
      try norm_num

theorem tP13SF_nonneg : ∀ k, 0 ≤ tP13SF k := by
  intro k
  fin_cases k <;>
    · simp [tP13SF]
      try norm_num

theorem dP13SF_nonneg : ∀ i, 0 ≤ dP13SF i := by
  intro i
  fin_cases i <;>
    · simp [dP13SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P13SF : ∀ a b, smP13SF a b
    = 2 * (if a = b then tP13SF a else 0) - vP13SF a * vP13SF b
      - (1/((1870627 : ℝ)/250000)) * (tP13SF a * (G1SF a b * tP13SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP13SF, tP13SF, vP13SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P13SF : ∀ a b, smP13SF a b = ∑ i, lP13SF a i * (dP13SF i * lP13SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP13SF, lP13SF, dP13SF, Fin.sum_univ_succ]
      try norm_num

theorem hS13SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP13SF k * z k) ^ 2
      + (1/((1870627 : ℝ)/250000)) * (∑ a, ∑ b, (tP13SF a * z a) * (G1SF a b * (tP13SF b * z b)))
      ≤ 2 * ∑ k, tP13SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP13SF lP13SF vP13SF tP13SF dP13SF
    dP13SF_nonneg h1P13SF h2P13SF

theorem pairSqSF_1_3 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 1 - mlpSF u 3) - (mlpSF u' 1 - mlpSF u' 3)) ^ 2
      ≤ ((1870627 : ℝ)/250000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 1 - mlpSF w 3
      = ∑ t, vP13SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 1 - mlpSF w 3
        = ∑ t, (W2SF 1 t - W2SF 3 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 1 3 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP13SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP13SF tP13SF tP13SF_nonneg (by norm_num)
    hS13SF u u'

