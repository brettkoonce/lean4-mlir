theorem vP15SF_eq : ∀ t, vP15SF t = W2SF 1 t - W2SF 5 t := by
  intro t
  fin_cases t <;>
    · simp [vP15SF, W2SF]
      try norm_num

theorem tP15SF_nonneg : ∀ k, 0 ≤ tP15SF k := by
  intro k
  fin_cases k <;>
    · simp [tP15SF]
      try norm_num

theorem dP15SF_nonneg : ∀ i, 0 ≤ dP15SF i := by
  intro i
  fin_cases i <;>
    · simp [dP15SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P15SF : ∀ a b, smP15SF a b
    = 2 * (if a = b then tP15SF a else 0) - vP15SF a * vP15SF b
      - (1/((1649697 : ℝ)/125000)) * (tP15SF a * (G1SF a b * tP15SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP15SF, tP15SF, vP15SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P15SF : ∀ a b, smP15SF a b = ∑ i, lP15SF a i * (dP15SF i * lP15SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP15SF, lP15SF, dP15SF, Fin.sum_univ_succ]
      try norm_num

theorem hS15SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP15SF k * z k) ^ 2
      + (1/((1649697 : ℝ)/125000)) * (∑ a, ∑ b, (tP15SF a * z a) * (G1SF a b * (tP15SF b * z b)))
      ≤ 2 * ∑ k, tP15SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP15SF lP15SF vP15SF tP15SF dP15SF
    dP15SF_nonneg h1P15SF h2P15SF

theorem pairSqSF_1_5 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 1 - mlpSF u 5) - (mlpSF u' 1 - mlpSF u' 5)) ^ 2
      ≤ ((1649697 : ℝ)/125000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 1 - mlpSF w 5
      = ∑ t, vP15SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 1 - mlpSF w 5
        = ∑ t, (W2SF 1 t - W2SF 5 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 1 5 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP15SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP15SF tP15SF tP15SF_nonneg (by norm_num)
    hS15SF u u'

