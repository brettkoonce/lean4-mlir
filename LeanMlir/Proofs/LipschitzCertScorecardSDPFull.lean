theorem h1P16SF : ∀ a b, smP16SF a b
    = 2 * (if a = b then tP16SF a else 0) - vP16SF a * vP16SF b
      - (1/((218819 : ℝ)/20000)) * (tP16SF a * (G1SF a b * tP16SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP16SF, tP16SF, vP16SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P16SF : ∀ a b, smP16SF a b = ∑ i, lP16SF a i * (dP16SF i * lP16SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP16SF, lP16SF, dP16SF, Fin.sum_univ_succ]
