theorem vP38SF_eq : ∀ t, vP38SF t = W2SF 3 t - W2SF 8 t := by
  intro t
  fin_cases t <;>
    · simp [vP38SF, W2SF]
      try norm_num

theorem tP38SF_nonneg : ∀ k, 0 ≤ tP38SF k := by
  intro k
  fin_cases k <;>
    · simp [tP38SF]
      try norm_num

theorem dP38SF_nonneg : ∀ i, 0 ≤ dP38SF i := by
  intro i
  fin_cases i <;>
    · simp [dP38SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P38SF : ∀ a b, smP38SF a b
    = 2 * (if a = b then tP38SF a else 0) - vP38SF a * vP38SF b
      - (1/((12045699 : ℝ)/1000000)) * (tP38SF a * (G1SF a b * tP38SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP38SF, tP38SF, vP38SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P38SF : ∀ a b, smP38SF a b = ∑ i, lP38SF a i * (dP38SF i * lP38SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP38SF, lP38SF, dP38SF, Fin.sum_univ_succ]
      try norm_num

theorem hS38SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP38SF k * z k) ^ 2
      + (1/((12045699 : ℝ)/1000000)) * (∑ a, ∑ b, (tP38SF a * z a) * (G1SF a b * (tP38SF b * z b)))
      ≤ 2 * ∑ k, tP38SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP38SF lP38SF vP38SF tP38SF dP38SF
    dP38SF_nonneg h1P38SF h2P38SF

theorem pairSqSF_3_8 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 3 - mlpSF u 8) - (mlpSF u' 3 - mlpSF u' 8)) ^ 2
      ≤ ((12045699 : ℝ)/1000000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 3 - mlpSF w 8
      = ∑ t, vP38SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 3 - mlpSF w 8
        = ∑ t, (W2SF 3 t - W2SF 8 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 3 8 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP38SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP38SF tP38SF tP38SF_nonneg (by norm_num)
    hS38SF u u'

