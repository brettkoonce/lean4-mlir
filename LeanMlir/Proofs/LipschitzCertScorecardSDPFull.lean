theorem h1P09SF : ∀ a b, smP09SF a b
    = 2 * (if a = b then tP09SF a else 0) - vP09SF a * vP09SF b
      - (1/((2959229 : ℝ)/250000)) * (tP09SF a * (G1SF a b * tP09SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP09SF, tP09SF, vP09SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P09SF : ∀ a b, smP09SF a b = ∑ i, lP09SF a i * (dP09SF i * lP09SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP09SF, lP09SF, dP09SF, Fin.sum_univ_succ]
      try norm_num

theorem hS09SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP09SF k * z k) ^ 2
      + (1/((2959229 : ℝ)/250000)) * (∑ a, ∑ b, (tP09SF a * z a) * (G1SF a b * (tP09SF b * z b)))
      ≤ 2 * ∑ k, tP09SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP09SF lP09SF vP09SF tP09SF dP09SF
    dP09SF_nonneg h1P09SF h2P09SF

theorem pairSqSF_0_9 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 0 - mlpSF u 9) - (mlpSF u' 0 - mlpSF u' 9)) ^ 2
      ≤ ((2959229 : ℝ)/250000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 0 - mlpSF w 9
      = ∑ t, vP09SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 0 - mlpSF w 9
        = ∑ t, (W2SF 0 t - W2SF 9 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 0 9 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP09SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP09SF tP09SF tP09SF_nonneg (by norm_num)
    hS09SF u u'

