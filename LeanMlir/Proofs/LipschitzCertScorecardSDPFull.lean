theorem vP67SF_eq : ∀ t, vP67SF t = W2SF 6 t - W2SF 7 t := by
  intro t
  fin_cases t <;>
    · simp [vP67SF, W2SF]
      try norm_num

theorem tP67SF_nonneg : ∀ k, 0 ≤ tP67SF k := by
  intro k
  fin_cases k <;>
    · simp [tP67SF]
      try norm_num

theorem dP67SF_nonneg : ∀ i, 0 ≤ dP67SF i := by
  intro i
  fin_cases i <;>
    · simp [dP67SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P67SF : ∀ a b, smP67SF a b
    = 2 * (if a = b then tP67SF a else 0) - vP67SF a * vP67SF b
      - (1/((10496647 : ℝ)/500000)) * (tP67SF a * (G1SF a b * tP67SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP67SF, tP67SF, vP67SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P67SF : ∀ a b, smP67SF a b = ∑ i, lP67SF a i * (dP67SF i * lP67SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP67SF, lP67SF, dP67SF, Fin.sum_univ_succ]
      try norm_num

theorem hS67SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP67SF k * z k) ^ 2
      + (1/((10496647 : ℝ)/500000)) * (∑ a, ∑ b, (tP67SF a * z a) * (G1SF a b * (tP67SF b * z b)))
      ≤ 2 * ∑ k, tP67SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP67SF lP67SF vP67SF tP67SF dP67SF
    dP67SF_nonneg h1P67SF h2P67SF

theorem pairSqSF_6_7 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 6 - mlpSF u 7) - (mlpSF u' 6 - mlpSF u' 7)) ^ 2
      ≤ ((10496647 : ℝ)/500000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 6 - mlpSF w 7
      = ∑ t, vP67SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 6 - mlpSF w 7
        = ∑ t, (W2SF 6 t - W2SF 7 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 6 7 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP67SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP67SF tP67SF tP67SF_nonneg (by norm_num)
    hS67SF u u'

