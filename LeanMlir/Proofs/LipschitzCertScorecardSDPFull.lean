theorem vP29SF_eq : ∀ t, vP29SF t = W2SF 2 t - W2SF 9 t := by
  intro t
  fin_cases t <;>
    · simp [vP29SF, W2SF]
      try norm_num

theorem tP29SF_nonneg : ∀ k, 0 ≤ tP29SF k := by
  intro k
  fin_cases k <;>
    · simp [tP29SF]
      try norm_num

theorem dP29SF_nonneg : ∀ i, 0 ≤ dP29SF i := by
  intro i
  fin_cases i <;>
    · simp [dP29SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h1P29SF : ∀ a b, smP29SF a b
    = 2 * (if a = b then tP29SF a else 0) - vP29SF a * vP29SF b
      - (1/((9271211 : ℝ)/500000)) * (tP29SF a * (G1SF a b * tP29SF b)) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP29SF, tP29SF, vP29SF, G1SF]
      try norm_num

set_option maxHeartbeats 12800000 in
theorem h2P29SF : ∀ a b, smP29SF a b = ∑ i, lP29SF a i * (dP29SF i * lP29SF b i) := by
  intro a b
  fin_cases a <;> fin_cases b <;>
    · simp [smP29SF, lP29SF, dP29SF, Fin.sum_univ_succ]
      try norm_num

theorem hS29SF : ∀ z : Fin 16 → ℝ,
    (∑ k, vP29SF k * z k) ^ 2
      + (1/((9271211 : ℝ)/500000)) * (∑ a, ∑ b, (tP29SF a * z a) * (G1SF a b * (tP29SF b * z b)))
      ≤ 2 * ∑ k, tP29SF k * z k ^ 2 :=
  lipsdp_slack_of_cert G1SF smP29SF lP29SF vP29SF tP29SF dP29SF
    dP29SF_nonneg h1P29SF h2P29SF

theorem pairSqSF_2_9 : ∀ u u' : EuclideanSpace ℝ (Fin 784),
    ((mlpSF u 2 - mlpSF u 9) - (mlpSF u' 2 - mlpSF u' 9)) ^ 2
      ≤ ((9271211 : ℝ)/500000) * ‖u - u'‖ ^ 2 := by
  intro u u'
  have e : ∀ w : EuclideanSpace ℝ (Fin 784), mlpSF w 2 - mlpSF w 9
      = ∑ t, vP29SF t * max (denseE W1SF w t) 0 := by
    intro w
    have h : mlpSF w 2 - mlpSF w 9
        = ∑ t, (W2SF 2 t - W2SF 9 t) * max (denseE W1SF w t) 0 :=
      mlp_gap_eq W1SF W2SF 2 9 w
    rw [h]
    exact Finset.sum_congr rfl fun t _ => by rw [vP29SF_eq t]
  rw [e u, e u']
  exact pair_sq_bound W1SF G1SF G1SF_eq vP29SF tP29SF tP29SF_nonneg (by norm_num)
    hS29SF u u'

